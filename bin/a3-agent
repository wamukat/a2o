#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require "a3"

options = {
  agent_name: ENV.fetch("A3_AGENT_NAME", "local-agent"),
  control_plane_url: ENV.fetch("A3_CONTROL_PLANE_URL", "http://127.0.0.1:7393")
}

OptionParser.new do |parser|
  parser.on("--agent NAME") { |value| options[:agent_name] = value }
  parser.on("--control-plane-url URL") { |value| options[:control_plane_url] = value }
end.parse!(ARGV)

client = A3::Agent::HttpControlPlaneClient.new(base_url: options.fetch(:control_plane_url))
result = A3::Agent::RunOnceWorker.new(
  agent_name: options.fetch(:agent_name),
  control_plane_client: client
).call

if result == :idle
  puts "agent idle"
else
  puts "agent completed #{result.job_id} status=#{result.status}"
end
